# Python
__pycache__/
*.py[cod]
*$py.class
*.so
build/
dist/
*.egg-info/
*.egg
.ruff_cache/

# Virtual environments
.env
.venv
env/
venv/

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# OS (macOS)
.DS_Store
._*

# Data files (exclude sensitive financial data)
data/
*.csv
*.pdf
*.xlsx
*.xls
# SQLMesh seed data is safe to track (static reference data, not financial)
!sqlmesh/models/seeds/*.csv
# Test fixtures are synthetic/non-sensitive and must be tracked for CI
!tests/fixtures/*.csv
!tests/fixtures/*.pdf
# Built-in CSV profiles are static config bundled with the package (not financial data)
!src/moneybin/data/

# Database files
*.duckdb
*.db
*.sqlite
*.sqlite3

# Logs
*.log
logs/

# Jupyter Notebook
.ipynb_checkpoints

# SQLMesh
sqlmesh/.cache/
sqlmesh/logs/

# Environment variables and secrets
.env
.env.local
.env.*.local
*.key
*.pem

# Test coverage
htmlcov/
.coverage
.coverage.*
.pytest_cache/

# dbt build artifacts
target/

# Pyright type checking
pyrightconfig.json

# Claude Code local settings (personal, not shared)
.claude/settings.local.json

# MCP config (contains local paths and credentials)
.mcp.json
.cursor/mcp.json

# Private docs (strategy, specs, notes — not for open source)
private/
